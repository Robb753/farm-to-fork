NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox — carte interactive (obligatoire)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Supabase (public — client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — ne jamais exposer côté client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk — routes (important pour build + redirections)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/explore
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/welcome

# Optional: JWT template Clerk → Supabase
NEXT_PUBLIC_CLERK_SUPABASE_TEMPLATE=supabase

# Twilio — SMS verification
NEXT_PUBLIC_TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# INSEE — SIRET/SIREN lookup
INSEE_API_KEY=